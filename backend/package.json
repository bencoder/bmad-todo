{
  "name": "aine-training-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "TEST=1 node --test --import tsx tests/todos.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3"
  }
}
